		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/typography": "^0.5.20",
		"@types/node": "^25.9.3",
		"drizzle-kit": "^0.31.10",
		"mdsvex": "^0.12.7",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	},
	"dependencies": {
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@tailwindcss/vite": "^4.3.0",
		"drizzle-orm": "^0.45.2",
